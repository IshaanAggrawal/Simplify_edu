  "leetcode_problems": [206],
  "languages": {
    "cpp": "ListNode* reverseList(ListNode* head) {\n    ListNode* prev = nullptr;\n    ListNode* curr = head;\n    while (curr != nullptr) {\n        ListNode* nextNode = curr->next;\n        curr->next = prev;\n        prev = curr;\n        curr = nextNode;\n    }\n    return prev;\n}",
    "python": "def reverseList(self, head: Optional[ListNode]) -> Optional[ListNode]:\n    prev = None\n    curr = head\n    while curr:\n        nextNode = curr.next\n        curr.next = prev\n        prev = curr\n        curr = nextNode\n    return prev"
  },
